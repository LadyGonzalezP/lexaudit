# Copiá este archivo como .env y completá el valor.
# El .env real NUNCA se sube al repositorio (está en .gitignore).

# API key de Google Gemini — gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui

# Modelo de chat para los agentes (opcional, este es el valor por defecto)
GEMINI_MODEL=gemini-2.0-flash
