# Copiá este archivo como .env y completá los valores.
# El .env real NUNCA se sube al repositorio (está en .gitignore).

# Proveedor de LLM para los agentes: "groq" (recomendado, free tier amplio) o "gemini"
LLM_PROVIDER=groq

# Groq — clave gratuita en https://console.groq.com
GROQ_API_KEY=tu-groq-api-key-aqui

# Google Gemini — usado para los embeddings del RAG.
# Clave gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-gemini-api-key-aqui
